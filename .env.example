# Veritasor Contracts Deployment - Copy to .env and fill

# Required
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org:443
STELLAR_SECRET_KEY=your_deployer_secret_key_here
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
CONTRACT_ADMIN_KEY=your_admin_secret_key_here

# Recommended
SOROBAN_FEE_ACCOUNT=your_fee_account_public_key
SOROBAN_FEE_SECRET_KEY=your_fee_secret_key_here

